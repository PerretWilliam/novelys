{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NODE_ENV": "production"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NODE_ENV": "production"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
